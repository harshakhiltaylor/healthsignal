# ============================================================
# HealthSignal — Environment Variables
# All services below have a FREE tier. No credit card needed.
# ============================================================

# --- Groq (free: 6k req/day) ---
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# --- HuggingFace (free serverless inference) ---
# Sign up: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# HuggingFace model IDs (free serverless inference API)
HF_NER_MODEL=d4data/biomedical-ner-all
HF_ZSC_MODEL=cross-encoder/nli-deberta-v3-base
HF_SUMMARY_MODEL=facebook/bart-large-cnn
HF_EMBED_MODEL=NLP4Science/pubmedbert-large-uncased

# --- Supabase PostgreSQL + pgvector (free: 500MB) ---
# Sign up: https://supabase.com
# Go to: Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# For local dev with docker-compose:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthsignal

# --- Upstash Redis (free: 10k cmd/day) ---
# Sign up: https://upstash.com → create free database
# OR use local Redis via docker-compose (no account needed)
REDIS_URL=redis://localhost:6379/0
# For Upstash: REDIS_URL=rediss://:password@host.upstash.io:6380

# --- ClinicalTrials.gov API (completely free, no key required) ---
CT_API_BASE=https://clinicaltrials.gov/api/v2
CT_BATCH_SIZE=100
CT_MAX_PAGES=50

# --- App Settings ---
APP_ENV=development
SECRET_KEY=change_this_to_a_random_32char_string
CORS_ORIGINS=http://localhost:3000

# --- Pipeline Settings ---
EMBED_CHUNK_SIZE=512
EMBED_CHUNK_OVERLAP=50
VECTOR_DIM=768

# --- Eval Settings ---
RAGAS_FAITHFULNESS_THRESHOLD=0.80
EVAL_SAMPLE_SIZE=50

# --- LangSmith (free: 5k traces/month) ---
# Sign up: https://smith.langchain.com
# Leave blank to disable tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=healthsignal

# --- Prometheus (self-hosted, free) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
